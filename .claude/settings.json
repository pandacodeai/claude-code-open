{
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Edit(*.ts)",
      "Bash(cd*)",
      "Edit(*.tsx)",
      "Edit(*.json)",
      "Bash(docker*)",
      "Write(*.sh)",
      "Write(*.bat)",
      "Edit(*.yml)",
      "Write(*.md)",
      "Write(*.ts)"
    ],
    "deny": []
  },
  "mcpServers": {
    "claude-in-chrome": {
      "type": "stdio",
      "command": "node",
      "args": [
        "F:\\claude-code-open\\dist\\cli.js",
        "--claude-in-chrome-mcp"
      ],
      "enabled": false,
      "timeout": 30000,
      "retries": 3
    }
  }
}