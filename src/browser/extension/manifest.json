{
  "manifest_version": 3,
  "name": "Axon Browser Bridge",
  "version": "1.0.37005",
  "description": "CDP relay bridge for Axon CLI - attach your Chrome tabs for AI control",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Axon Browser Bridge (click to attach/detach)"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}